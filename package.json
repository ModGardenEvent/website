{
  "name": "mod-garden-website",
  "type": "module",
  "version": "1.5.1",
  "scripts": {
    "dev": "astro dev --api real",
    "dev_local": "astro dev --api local",
    "start": "node ./dist/server/entry.mjs --api real",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^10.1.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@ungap/map-extensions": "^0.1.1",
    "astro": "^6.4.8",
    "astro-icon": "^1.1.5",
    "flowbite": "^4.0.2",
    "moment": "^2.30.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@11ty/eleventy-fetch": "^5.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.0.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
